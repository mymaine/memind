# ─── LLM (via OpenRouter's Anthropic-compatible endpoint) ─────
# All agent calls route through https://openrouter.ai/api/v1/messages
# using model `anthropic/claude-sonnet-4-5`. Get a key at
# https://openrouter.ai/keys (top up with at least $5 — Claude isn't free).
OPENROUTER_API_KEY=sk-or-v1-...

# ─── Image generation (Google Gemini 2.5 Flash Image) ─
# Get a key at https://aistudio.google.com/apikey with a billing-enabled
# Google account. Format AIza... (39 chars). ~$0.039 per image.
GOOGLE_API_KEY=AIza...

# ─── X API (Phase 3 onward) ───────────────────────────
# Scope: agent auto-posting + reading its own timeline only. No
# broadcast, no hashtag spam, no @mention of strangers.
#
# Create an app at https://developer.x.com/en/portal/dashboard with
# Read+Write permissions. We use OAuth 1.0a user context (the agent
# posts as a specific user, not app-only). Use a long-lived 10yr+
# account to avoid shadow-ban; brand new accounts get auto-flagged.
#
# Pricing: pay-per-usage. Content: Create ~= $0.010/post (re-verify at
# docs.x.com/x-api/getting-started/pricing before demo — a 2026-04-20
# revision was reported). URL posts may be surcharged up to $0.20 — avoid
# embedding bscscan links in tweet body. Budget ~$5 covers the run.
X_API_KEY=
X_API_KEY_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=
X_BEARER_TOKEN=

# ─── IPFS (Pinata) ────────────────────────────────────
PINATA_JWT=

# ─── Agent wallet (Base Sepolia, holds test USDC for x402 payments) ──
AGENT_WALLET_PRIVATE_KEY=0x
AGENT_WALLET_ADDRESS=0x

# ─── BSC mainnet wallet (holds REAL BNB for four.meme token deploy) ──
# four.meme TokenManager2 only exists on BSC mainnet (chainId 56).
# deployCost=0 + ~$0.05 gas per deploy. $1 of BNB covers many iterations.
BSC_DEPLOYER_PRIVATE_KEY=0x
BSC_DEPLOYER_ADDRESS=0x

# Optional RPC overrides (defaults: public nodes)
# BSC_MAINNET_RPC_URL=https://bsc-dataseed.binance.org
# BSC_TESTNET_RPC_URL=https://data-seed-prebsc-1-s1.binance.org:8545

# ─── x402 facilitator (Base Sepolia default) ──────────
X402_FACILITATOR_URL=https://x402.org/facilitator
X402_NETWORK=eip155:84532

# ─── Server ports ─────────────────────────────────────
WEB_PORT=3000
SERVER_PORT=4000

# ─── Dashboard demo pre-seed artifacts (optional) ─────
# Full-hash values from a previous Creator / Phase 2 run. When set, the
# a2a dashboard lights all 5 pills; when unset, the run still works but
# shows only 3 (bsc-token + Narrator lore CID + x402 USDC tx).
# DEMO_TOKEN_DEPLOY_TX=0x<64 hex chars>
# DEMO_CREATOR_LORE_CID=bafkrei<rest of the CID>

