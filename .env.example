# ─── LLM (via OpenRouter's Anthropic-compatible endpoint) ─────
# All agent calls route through https://openrouter.ai/api/v1/messages
# using model `anthropic/claude-sonnet-4-5`. Get a key at
# https://openrouter.ai/keys (top up with at least $5 — Claude isn't free).
OPENROUTER_API_KEY=sk-or-v1-...

# ─── Image generation (Google Gemini 2.5 Flash Image) ─
# Get a key at https://aistudio.google.com/apikey with a billing-enabled
# Google account. Format AIza... (39 chars). ~$0.039 per image.
GOOGLE_API_KEY=AIza...

# ─── IPFS (Pinata) ────────────────────────────────────
PINATA_JWT=

# ─── Agent wallet (Base Sepolia, holds test USDC for x402 payments) ──
AGENT_WALLET_PRIVATE_KEY=0x
AGENT_WALLET_ADDRESS=0x

# ─── BSC mainnet wallet (holds REAL BNB for four.meme token deploy) ──
# four.meme TokenManager2 only exists on BSC mainnet (chainId 56).
# deployCost=0 + ~$0.05 gas per deploy. $1 of BNB covers many iterations.
BSC_DEPLOYER_PRIVATE_KEY=0x
BSC_DEPLOYER_ADDRESS=0x

# Optional RPC overrides (defaults: public nodes)
# BSC_MAINNET_RPC_URL=https://bsc-dataseed.binance.org
# BSC_TESTNET_RPC_URL=https://data-seed-prebsc-1-s1.binance.org:8545

# ─── x402 facilitator (Base Sepolia default) ──────────
X402_FACILITATOR_URL=https://x402.org/facilitator
X402_NETWORK=eip155:84532

# ─── Server ports ─────────────────────────────────────
WEB_PORT=3000
SERVER_PORT=4000
