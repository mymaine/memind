# LLM — Claude Sonnet 4.5 via OpenRouter. https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Image — Gemini 2.5 Flash Image. https://aistudio.google.com/apikey
GOOGLE_API_KEY=

# IPFS — Pinata JWT. https://app.pinata.cloud/developers/api-keys
PINATA_JWT=
# PINATA_GATEWAY=gateway.pinata.cloud

# X API — OAuth 1.0a user context. https://developer.x.com
X_API_KEY=
X_API_KEY_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=
X_BEARER_TOKEN=
# X_HANDLE=

# Agent wallet — Base Sepolia, holds test USDC for x402 settlements.
AGENT_WALLET_PRIVATE_KEY=
AGENT_WALLET_ADDRESS=

# Deployer wallet — BSC mainnet, holds real BNB (~$1 covers many deploys).
BSC_DEPLOYER_PRIVATE_KEY=
BSC_DEPLOYER_ADDRESS=

# x402 (defaults target Base Sepolia USDC)
X402_FACILITATOR_URL=https://www.x402.org/facilitator
X402_NETWORK=eip155:84532
# Facilitator mode: `local` runs in-process (signs with AGENT_WALLET_PRIVATE_KEY,
# needs Base Sepolia ETH for gas) — default because the public facilitator's
# /settle was broken on 2026-04-21. Set to `http` to delegate to
# X402_FACILITATOR_URL (x402.org, CDP, self-hosted x402.rs, etc).
X402_FACILITATOR_MODE=local

# BSC RPC override (default: public bsc-dataseed node)
# BSC_RPC_URL=https://bsc-dataseed.binance.org

# Web → server origin. Unset for local dev; set to the server URL in prod.
# NEXT_PUBLIC_SERVER_ORIGIN=

# Ports
WEB_PORT=3000
SERVER_PORT=4000

# Heartbeat tick interval (ms). Default 60000; lower for demo captures.
# HEARTBEAT_INTERVAL_MS=

# Degrade flags — flip to true if a live API goes down mid-demo.
# CREATOR_DRY_RUN=false
# SHILL_DRY_RUN=false

# On-chain BSC mainnet anchor layer (optional).
# When true, each narrator chapter fires a zero-value memo tx on BSC mainnet
# carrying the content-hash commitment (~$0.01 BNB gas per chapter).
# Default false to avoid accidental spend. Requires BSC_DEPLOYER_PRIVATE_KEY.
ANCHOR_ON_CHAIN=false

# Demo pre-seed (optional; lights additional artifact pills)
# DEMO_TOKEN_ADDR=
# DEMO_TOKEN_DEPLOY_TX=
# DEMO_CREATOR_LORE_CID=

# Postgres (Memind persistence layer). Required at runtime — the server
# fails fast on boot when DATABASE_URL is missing. `docker compose up -d
# postgres` starts a local container at exactly this URL. Railway injects
# its own DATABASE_URL automatically via the Postgres plugin.
DATABASE_URL=postgres://memind:memind@localhost:5432/memind
# TEST_DATABASE_URL=postgres://memind:memind@localhost:5432/memind
# PG_POOL_MAX=5
